# PostgreSQL
POSTGRES_USER=vow_pact
POSTGRES_PASSWORD=
POSTGRES_DB=vow_pact_development

# Rails -> DB 接続URL
# 形式: postgresql://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgresql://vow_pact:PASSWORD@db:5432/vow_pact_development

# フロントエンドURL
FRONTEND_URL=http://localhost:3000

# CORS で許可するオリジン（React フロントエンド）
# vite_rails ハイブリッド構成では dev は同一オリジン（localhost:3000）になるため
# 実質 prod 用。Vite を独立サーバー化する場合は localhost:3036 を許可
FRONTEND_ORIGIN=http://localhost:3036

# OpenAI API
OPENAI_API_KEY=
